# Supabase (client-side, requires VITE_ prefix for Vite)
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Gemini AI (server-side only)
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Auth (server-side only)
JWT_SECRET="YOUR_JWT_SECRET"

# Auth0 (server-side only)
AUTH0_DOMAIN="YOUR_AUTH0_DOMAIN"
AUTH0_CLIENT_ID="YOUR_AUTH0_CLIENT_ID"
AUTH0_CLIENT_SECRET="YOUR_AUTH0_CLIENT_SECRET"

# Facebook OAuth (server-side only, for channel connections)
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"

# LinkedIn OAuth (server-side only, for channel connections)
LINKEDIN_CLIENT_ID="YOUR_LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="YOUR_LINKEDIN_CLIENT_SECRET"

# Redis (server-side only, for BullMQ scheduler/publisher)
REDIS_URL="redis://localhost:6379"

# App URL (server-side only, used for OAuth redirects)
APP_URL="http://localhost:3000"
